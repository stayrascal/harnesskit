#!/usr/bin/env bash
set -euo pipefail

echo "Starting {{ project_name }}..."
bun run src/index.ts &
SERVER_PID=$!

for i in $(seq 1 30); do
    if curl -sf http://127.0.0.1:3000/healthz > /dev/null 2>&1; then
        echo "Server is up!"
        break
    fi
    sleep 0.5
done

curl -sf http://127.0.0.1:3000/healthz | grep -q '"status":"ok"' && echo "Health OK" || { echo "Health failed"; kill $SERVER_PID; exit 1; }
curl -sf http://127.0.0.1:3000/ | grep -q "<html" && echo "Home page OK" || { echo "Page failed"; kill $SERVER_PID; exit 1; }

kill $SERVER_PID 2>/dev/null || true
echo "Done."
