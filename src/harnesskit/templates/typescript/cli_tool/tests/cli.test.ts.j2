import { describe, expect, test } from "bun:test";

describe("cli", () => {
	test("hello command exists", async () => {
		const proc = Bun.spawn(["bun", "run", "src/index.ts", "hello"], {
			stdout: "pipe",
		});
		const output = await new Response(proc.stdout).text();
		expect(output).toContain("Hello, World!");
	});

	test("hello with name", async () => {
		const proc = Bun.spawn(["bun", "run", "src/index.ts", "hello", "Alice"], {
			stdout: "pipe",
		});
		const output = await new Response(proc.stdout).text();
		expect(output).toContain("Hello, Alice!");
	});
});
